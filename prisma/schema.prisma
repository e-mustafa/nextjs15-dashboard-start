generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// user -----------------------------------
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime? @map("email_verified")
  password      String?   @db.Text
  accounts      Account[]
  sessions      Session[]
  role          UserRole  @default(user)

  imageId String? // مفتاح أجنبي اختياري
  image   Image?  @relation(fields: [imageId], references: [id])

  Authenticator Authenticator[]
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @default(now()) @updatedAt
  Post          Post[]

  @@map("users")
}

enum UserRole {
  user
  admin
  moderator
}

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// Optional for WebAuthn support
model Authenticator {
  credentialID         String  @unique
  userId               String
  providerAccountId    String
  credentialPublicKey  String
  counter              Int
  credentialDeviceType String
  credentialBackedUp   Boolean
  transports           String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, credentialID])
}

// Dashboard schema -------------------------------------------------
// post -----------------------------------
model Post {
  id        String   @id @default(cuid())
  title     String
  content   String?
  published Boolean  @default(false)
  author    User     @relation(fields: [authorId], references: [id])
  authorId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
}

// products -----------------------------------
model Product {
  id          String   @id @default(cuid())
  name        String
  description String?
  basePrice   Float
  price       Float
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt

  images ProductImage[]

  Category   Category? @relation(fields: [categoryId], references: [id])
  categoryId String?
  Brand      Brand?    @relation(fields: [brandId], references: [id])
  brandId    String?
}

model ProductImage {
  id        String @id @default(cuid())
  productId String
  imageId   String

  product Product @relation(fields: [productId], references: [id])
  image   Image   @relation(fields: [imageId], references: [id])

  @@unique([productId, imageId]) // كل صورة مرة واحدة فقط لكل منتج
}

// brand -----------------------------------
model Brand {
  id           String             @id @default(cuid())
  imageId      String? // مفتاح أجنبي اختياري
  image        Image?             @relation(fields: [imageId], references: [id])
  updatedAt    DateTime           @default(now()) @updatedAt
  createdAt    DateTime           @default(now())
  products     Product[]
  translations BrandTranslation[]
}

model BrandTranslation {
  id          String @id @default(cuid())
  brandId     String
  lang        String
  slug        String
  name        String
  description String
  Brand       Brand  @relation(fields: [brandId], references: [id], onDelete: Cascade)

  @@unique([brandId, lang], name: "brandId_lang") // ✅ أضف الاسم هنا
  @@unique([lang, slug], name: "lang_slug")
  @@index([name])
  @@index([slug])
}

model Category {
  id          String  @id @default(cuid())
  imageId     String? // الصورة الرئيسية
  seo_imageId String? // صورة الـ SEO

  // علاقات الصور
  image     Image? @relation("CategoryImage", fields: [imageId], references: [id])
  seo_image Image? @relation("CategorySeoImage", fields: [seo_imageId], references: [id])

  // باقي العلاقات
  products     Product[] // المنتجات التابعة للتصنيف
  translations CategoryTranslation[] // الترجمات
  updatedAt    DateTime              @default(now()) @updatedAt
  createdAt    DateTime              @default(now())
}

model CategoryTranslation {
  id              String   @id @default(cuid())
  categoryId      String
  lang            String
  slug            String
  name            String
  description     String
  seo_title       String?
  seo_description String?
  seo_keywords    String?
  Category        Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([categoryId, lang], name: "categoryId_lang")
  @@unique([lang, slug], name: "lang_slug")
  @@index([name])
  @@index([slug])
}

model Image {
  id        String   @id @default(cuid())
  fileId    String
  url       String
  createdAt DateTime @default(now())

  // العلاقات
  users          User[]
  brands         Brand[]
  categories     Category[]     @relation("CategoryImage") // 🔗 ترابط الصورة الرئيسية
  categories_seo Category[]     @relation("CategorySeoImage") // 🔗 ترابط صورة الـ SEO
  products       ProductImage[]
}
