generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ENUMS
/// //////////////////////
enum UserRole {
  user
  admin
  moderator
}

enum AttributeType {
  COLOR
  SIZE
  MATERIAL
  STYLE
  CUSTOM
}

enum CouponType {
  BUY_X_GET_Y
  BUNDLE
  SHIPPING
}

enum DiscountType {
  FIXED
  PERCENTAGE
}

enum ProductType {
  SIMPLE
  VARIABLE
  DIGITAL
  SERVICE
}
/////////////////////////
model User {
  id             String          @id @default(cuid())
  name           String?
  email          String          @unique
  emailVerified  DateTime?       @map("email_verified")
  password       String?
  imageId        String?
  role           UserRole        @default(user)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  accounts       Account[]
  authenticators Authenticator[]
  posts          Post[]
  sessions       Session[]
  image          Image?          @relation("UserImage", fields: [imageId], references: [id])

  @@index([email])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Authenticator {
  credentialID         String  @unique
  userId               String
  providerAccountId    String
  credentialPublicKey  String
  counter              Int
  credentialDeviceType String
  credentialBackedUp   Boolean
  transports           String?
  user                 User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, credentialID])
}

/// //////////////////////
/// //////////////////////
model Post {
  id        String   @id @default(cuid())
  title     String
  content   String?
  published Boolean  @default(false)
  authorId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
}

/// //////////////////////
/// //////////////////////
model Image {
  id               String            @id @default(cuid())
  fileId           String
  url              String
  createdAt        DateTime          @default(now())
  brandsMain       Brand[]           @relation("BrandMainImage")
  brandsSeo        Brand[]           @relation("BrandSeoImage")
  brandImages      BrandImage[]
  categoriesMain   Category[]        @relation("CategoryMainImage")
  categoriesSeo    Category[]        @relation("CategorySeoImage")
  categoryImages   CategoryImage[]
  collectionsMain  Collection[]      @relation("CollectionMainImage")
  collectionsSeo   Collection[]      @relation("CollectionSeoImage")
  collectionImages CollectionImage[]
  productsDirect   Product[]         @relation("ProductDirectImage")
  productsSeo      Product[]         @relation("ProductSeoImage")
  productImages    ProductImage[]
  variantImages    ProductVariant[]
  users            User[]            @relation("UserImage")
  variantImagesNew VariantImage[]    @relation("VariantImages")
}

/// //////////////////////
/// //////////////////////
model Brand {
  id           String             @id @default(cuid())
  imageId      String?
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  isActive     Boolean            @default(true)
  sortOrder    Int                @default(0)
  seoImageId   String?
  image        Image?             @relation("BrandMainImage", fields: [imageId], references: [id])
  seoImage     Image?             @relation("BrandSeoImage", fields: [seoImageId], references: [id])
  images       BrandImage[]
  translations BrandTranslation[]
  products     Product[]

  @@index([isActive])
  @@index([sortOrder])
}

model BrandTranslation {
  id             String  @id @default(cuid())
  brandId        String
  lang           String
  slug           String
  name           String
  description    String?
  seoDescription String?
  seoKeywords    String?
  seoTitle       String?
  brand          Brand   @relation(fields: [brandId], references: [id], onDelete: Cascade)

  @@unique([brandId, lang])
  @@unique([lang, slug])
  @@index([name])
}

model BrandImage {
  id        String  @id @default(cuid())
  brandId   String
  imageId   String
  sortOrder Int     @default(0)
  isPrimary Boolean @default(false)
  brand     Brand   @relation(fields: [brandId], references: [id], onDelete: Cascade)
  image     Image   @relation(fields: [imageId], references: [id], onDelete: Cascade)

  @@unique([brandId, imageId])
  @@index([brandId, sortOrder])
}

model Category {
  id           String                @id @default(cuid())
  imageId      String?
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt
  isActive     Boolean               @default(true)
  parentId     String?
  sortOrder    Int                   @default(0)
  seoImageId   String?
  image        Image?                @relation("CategoryMainImage", fields: [imageId], references: [id])
  parent       Category?             @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children     Category[]            @relation("CategoryHierarchy")
  seoImage     Image?                @relation("CategorySeoImage", fields: [seoImageId], references: [id])
  images       CategoryImage[]
  translations CategoryTranslation[]
  products     Product[]

  @@index([parentId])
  @@index([isActive])
  @@index([sortOrder])
}

model CategoryTranslation {
  id             String   @id @default(cuid())
  categoryId     String
  lang           String
  slug           String
  name           String
  description    String?
  seoDescription String?
  seoKeywords    String?
  seoTitle       String?
  category       Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([categoryId, lang])
  @@unique([lang, slug])
  @@index([name])
}

model CategoryImage {
  id         String   @id @default(cuid())
  categoryId String
  imageId    String
  sortOrder  Int      @default(0)
  isPrimary  Boolean  @default(false)
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  image      Image    @relation(fields: [imageId], references: [id], onDelete: Cascade)

  @@unique([categoryId, imageId])
  @@index([categoryId, sortOrder])
}

/// //////////////////////
/// //////////////////////
model Collection {
  id           String                  @id @default(cuid())
  imageId      String?
  isActive     Boolean                 @default(true)
  isFeatured   Boolean                 @default(false)
  sortOrder    Int                     @default(0)
  createdAt    DateTime                @default(now())
  updatedAt    DateTime                @updatedAt
  seoImageId   String?
  image        Image?                  @relation("CollectionMainImage", fields: [imageId], references: [id])
  seoImage     Image?                  @relation("CollectionSeoImage", fields: [seoImageId], references: [id])
  images       CollectionImage[]
  products     CollectionProduct[]
  translations CollectionTranslation[]

  @@index([isActive])
  @@index([isFeatured])
  @@index([sortOrder])
}

model CollectionTranslation {
  id             String     @id @default(cuid())
  collectionId   String
  lang           String
  slug           String
  name           String
  description    String?
  seoDescription String?
  seoKeywords    String?
  seoTitle       String?
  collection     Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)

  @@unique([collectionId, lang])
  @@unique([lang, slug])
  @@index([name])
}

model CollectionImage {
  id           String     @id @default(cuid())
  collectionId String
  imageId      String
  sortOrder    Int        @default(0)
  isPrimary    Boolean    @default(false)
  collection   Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  image        Image      @relation(fields: [imageId], references: [id], onDelete: Cascade)

  @@unique([collectionId, imageId])
  @@index([collectionId, sortOrder])
}

model CollectionProduct {
  collectionId String
  productId    String
  sortOrder    Int        @default(0)
  collection   Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  product      Product    @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@id([collectionId, productId])
  @@index([collectionId, sortOrder])
}

/// //////////////////////
/// //////////////////////
model Tag {
  id        String       @id @default(cuid())
  name      String       @unique
  slug      String       @unique
  createdAt DateTime     @default(now())
  products  ProductTag[]

  @@index([name])
  @@index([slug])
}

model ProductTag {
  productId String
  tagId     String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  tag       Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([productId, tagId])
  @@index([productId])
  @@index([tagId])
}

model Product {
  id             String                    @id @default(cuid())
  basePrice      Float
  createdAt      DateTime                  @default(now())
  updatedAt      DateTime                  @updatedAt
  categoryId     String?
  brandId        String?
  compareAtPrice Float?
  cost           Float?
  isActive       Boolean                   @default(true)
  isFeatured     Boolean                   @default(false)
  lowStockAlert  Int?
  publishedAt    DateTime?
  sku            String                    @unique
  sortOrder      Int                       @default(0)
  stockQuantity  Int                       @default(0)
  trackInventory Boolean                   @default(true)
  imageId        String?
  seoImageId     String?
  height         Float?
  length         Float?
  type           String?
  weight         Float?
  width          Float?
  collections    CollectionProduct[]
  brand          Brand?                    @relation(fields: [brandId], references: [id])
  category       Category?                 @relation(fields: [categoryId], references: [id])
  image          Image?                    @relation("ProductDirectImage", fields: [imageId], references: [id])
  seoImage       Image?                    @relation("ProductSeoImage", fields: [seoImageId], references: [id])
  attributes     ProductAttribute[]
  discounts      ProductDiscountRelation[]
  images         ProductImage[]
  specifications ProductSpecification[]
  tags           ProductTag[]
  translations   ProductTranslation[]
  variants       ProductVariant[]

  @@index([sku])
  @@index([brandId])
  @@index([categoryId])
  @@index([isActive])
  @@index([isFeatured])
  @@index([publishedAt])
  @@index([sortOrder])
}

model ProductTranslation {
  id               String  @id @default(cuid())
  productId        String
  lang             String
  name             String
  slug             String
  description      String?
  shortDescription String?
  seoDescription   String?
  seoKeywords      String?
  seoTitle         String?
  product          Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, lang])
  @@unique([lang, slug])
  @@index([name])
}

model ProductImage {
  id        String  @id @default(cuid())
  productId String
  imageId   String
  isPrimary Boolean @default(false)
  sortOrder Int     @default(0)
  image     Image   @relation(fields: [imageId], references: [id], onDelete: Cascade)
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, imageId])
  @@index([productId, sortOrder])
  @@index([productId, isPrimary])
}

/// //////////////////////
/// //////////////////////
model ProductVariant {
  id             String          @id @default(cuid())
  productId      String
  sku            String          @unique
  price          Float?
  compareAtPrice Float?
  cost           Float?
  stockQuantity  Int             @default(0)
  imageId        String?
  isActive       Boolean         @default(true)
  sortOrder      Int             @default(0)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @default(now()) @updatedAt
  image          Image?          @relation(fields: [imageId], references: [id])
  product        Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  images         VariantImage[]
  options        VariantOption[]

  @@index([productId])
  @@index([sku])
  @@index([isActive])
  @@index([sortOrder])
}

model Attribute {
  id             String                 @id @default(cuid())
  type           AttributeType
  sortOrder      Int                    @default(0)
  createdAt      DateTime               @default(now())
  translations   AttributeTranslation[]
  values         AttributeValue[]
  products       ProductAttribute[]
  variantOptions VariantOption[]

  @@index([type])
  @@index([sortOrder])
}

model AttributeTranslation {
  id          String    @id @default(cuid())
  attributeId String
  lang        String
  name        String
  attribute   Attribute @relation(fields: [attributeId], references: [id], onDelete: Cascade)

  @@unique([attributeId, lang])
  @@index([name])
}

model AttributeValue {
  id             String                      @id @default(cuid())
  attributeId    String
  value          String
  colorHex       String?
  sortOrder      Int                         @default(0)
  attribute      Attribute                   @relation(fields: [attributeId], references: [id], onDelete: Cascade)
  translations   AttributeValueTranslation[]
  products       ProductAttribute[]
  variantOptions VariantOption[]

  @@index([attributeId])
  @@index([sortOrder])
}

model AttributeValueTranslation {
  id               String         @id @default(cuid())
  attributeValueId String
  lang             String
  name             String
  attributeValue   AttributeValue @relation(fields: [attributeValueId], references: [id], onDelete: Cascade)

  @@unique([attributeValueId, lang])
  @@index([name])
}

model ProductAttribute {
  id               String         @id @default(cuid())
  productId        String
  attributeId      String
  attributeValueId String
  attribute        Attribute      @relation(fields: [attributeId], references: [id])
  attributeValue   AttributeValue @relation(fields: [attributeValueId], references: [id])
  product          Product        @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, attributeId, attributeValueId])
  @@index([productId])
  @@index([attributeId])
}

model VariantOption {
  id               String         @id @default(cuid())
  variantId        String
  attributeId      String
  attributeValueId String
  attribute        Attribute      @relation(fields: [attributeId], references: [id])
  attributeValue   AttributeValue @relation(fields: [attributeValueId], references: [id])
  variant          ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@unique([variantId, attributeId])
  @@index([variantId])
  @@index([attributeId])
}

model VariantImage {
  id        String         @id @default(cuid())
  variantId String
  imageId   String
  isPrimary Boolean        @default(false)
  sortOrder Int            @default(0)
  image     Image          @relation("VariantImages", fields: [imageId], references: [id], onDelete: Cascade)
  variant   ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@unique([variantId, imageId])
  @@index([variantId, sortOrder])
  @@index([variantId, isPrimary])
}

model ProductSpecification {
  id         String                         @id @default(cuid())
  productId  String
  title_ar   String
  title_en   String
  sortOrder  Int                            @default(0)
  createdAt  DateTime                       @default(now())
  updatedAt  DateTime                       @updatedAt
  product    Product                        @relation(fields: [productId], references: [id], onDelete: Cascade)
  properties ProductSpecificationProperty[]

  @@index([productId])
  @@index([sortOrder])
}

model ProductSpecificationProperty {
  id              String               @id @default(cuid())
  specificationId String
  key_ar          String
  key_en          String
  value_ar        String
  value_en        String
  sortOrder       Int                  @default(0)
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  specification   ProductSpecification @relation(fields: [specificationId], references: [id], onDelete: Cascade)

  @@index([specificationId])
  @@index([sortOrder])
}

model ProductDiscount {
  id               String                    @id @default(cuid())
  type             DiscountType
  value            Float
  startDate        DateTime
  endDate          DateTime?
  isActive         Boolean                   @default(true)
  priority         Int                       @default(0)
  createdAt        DateTime                  @default(now())
  updatedAt        DateTime                  @default(now()) @updatedAt
  maxDiscountValue Float?
  minDiscountValue Float?
  name_ar          String
  name_en          String
  products         ProductDiscountRelation[]

  @@index([startDate, endDate])
  @@index([isActive])
  @@index([priority])
  @@index([type])
}

model ProductDiscountRelation {
  id         String          @id @default(cuid())
  productId  String
  discountId String
  createdAt  DateTime        @default(now())
  discount   ProductDiscount @relation(fields: [discountId], references: [id], onDelete: Cascade)
  product    Product         @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, discountId])
  @@index([productId])
  @@index([discountId])
}

/// //////////////////////
